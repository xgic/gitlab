# =============================================
# XGIC GitLab (public exemplary)
# Root .gitignore for the generalized production GitLab EE stack.
# =============================================

# =============================================
# Environment & secrets (CRITICAL)
# =============================================
.env
.env*.local
.env.development
.env.production
.env.test
**/.env
**/.env*.local
**/.env.development
**/.env.production
**/.env.test
*.pem
*.key
*token*
*pat*
*credential*
*secret*

# =============================================
# GitLab runtime data (from docker-compose mounts)
# Never commit persistent or generated data.
# =============================================
gitlab-data/
gitlab-logs/
gitlab-config/
gitlab-backups/
postgres-data/
redis-data/
shared/

# =============================================
# Docker / container runtime
# =============================================
.docker/
docker-compose.override.yml
*.log

# =============================================
# Python (for any local tooling or xde usage during development)
# =============================================
__pycache__/
*.py[cod]
*$py.class
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
.ruff_cache/
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.ipynb_checkpoints
.python-version
.pdm.toml
.pdm-python
.pdm-build/
__pypackages__/
.pytype/
.ruff_cache/

# =============================================
# Logs & debug
# =============================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
Thumbs.db
*.orig

# =============================================
# Editor & IDE (team-shared allowed)
# =============================================
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/
.idea/
*.swp
*.swo

# =============================================
# Custom Copilot / AI agent local overrides (never commit)
# =============================================
AGENTS.local.md
CLAUDE.local.md
.claude/
.worktrees/

# =============================================
# GitLab CI local artifacts and temp
# =============================================
.gitlab-ci-local/
artifacts/
cache/
**/tmp/
**/tmp-*/
**/changes-*.patch

# =============================================
# Miscellaneous
# =============================================
.vercel
coverage/

# Session-injected files (local only)
prompt.md
