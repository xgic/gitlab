# XGIC GitLab template — example environment
# Copy to .env and customize. Never commit real secrets.
# Do not hard-code private production hosts in committed files.

# --- XGIC orchestration image (built by xgic/gitlab-dev) ---
XGIC_GITLAB_IMAGE=ghcr.io/xgic/xgic-gitlab
XGIC_GITLAB_TAG=latest
XGIC_GITLAB_PORT=8080

# --- Official GitLab EE (vendor image, pin for production) ---
# Re-verify patch/upgrade path before production cutover.
GITLAB_VERSION=18.11.7-ee.0
GITLAB_EXTERNAL_URL=http://localhost:8929
GITLAB_HTTP_PORT=8929
GITLAB_SSH_PORT=2224

TZ=UTC

# --- PostgreSQL 18 (official) ---
POSTGRES_VERSION=18
POSTGRES_DB=gitlabhq_production
POSTGRES_USER=gitlab
POSTGRES_PASSWORD=CHANGE_ME_STRONG

# --- Redis 8.8 (official) ---
REDIS_VERSION=8.8

# --- Volume paths (local defaults; use managed volumes in production) ---
GITLAB_DATA_DIR=./gitlab-data
GITLAB_LOGS_DIR=./gitlab-logs
GITLAB_CONFIG_DIR=./gitlab-config
GITLAB_BACKUPS_DIR=./gitlab-backups
POSTGRES_DATA_DIR=./postgres-data
REDIS_DATA_DIR=./redis-data
