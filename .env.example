# =============================================
# XGIC GitLab Stack — Example Environment
# Copy to .env and customize. Never commit real secrets.
# =============================================

# GitLab version pin (use exact stable EE tag, e.g. 17.11.0-ee.0)
GITLAB_VERSION=17.11.0-ee.0

# External URL for GitLab (required)
GITLAB_EXTERNAL_URL=https://gitlab.example.com

# Timezone
TZ=UTC

# PostgreSQL (external for production scalability)
POSTGRES_VERSION=16
POSTGRES_DB=gitlabhq_production
POSTGRES_USER=gitlab
# Generate a strong password for production
POSTGRES_PASSWORD=CHANGE_ME_STRONG

# Redis (optional but recommended)
REDIS_VERSION=7

# GitLab omnibus additional config (multi-line supported in compose)
# GITLAB_OMNIBUS_CONFIG=

# Volume paths (relative or absolute)
GITLAB_DATA_DIR=./gitlab-data
GITLAB_LOGS_DIR=./gitlab-logs
GITLAB_CONFIG_DIR=./gitlab-config
POSTGRES_DATA_DIR=./postgres-data
